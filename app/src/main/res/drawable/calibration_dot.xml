<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#80FFB3C1"/>
            <size android:width="64dp" android:height="64dp"/>
        </shape>
    </item>
    <!-- Inner filled circle -->
    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#FFE94560"/>
            <stroke android:width="2dp" android:color="#FFFFFFFF"/>
        </shape>
    </item>
    <!-- Center dot -->
    <item
        android:left="22dp"
        android:top="22dp"
        android:right="22dp"
        android:bottom="22dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF"/>
        </shape>
    </item>
</layer-list>
