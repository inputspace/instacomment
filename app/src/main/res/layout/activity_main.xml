<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:padding="24dp">

    <!-- Service warning banner (hidden when service is active) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bannerServiceOff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#CC2D0000"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="⚠ Accessibility service is off. Tap the button below to enable it."
            android:textColor="#FFEEEE"
            android:textSize="13sp"/>

    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment Blocker"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/bannerServiceOff"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="for Instagram Reels"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp"/>

    <!-- Main toggle card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvToggleLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Block Comments"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/switchBlock"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:trackTint="@color/accent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/tvToggleLabel"/>

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#30FFFFFF"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvToggleLabel"
                app:layout_constraintStart_toStartOf="parent"/>

            <View
                android:id="@+id/statusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_inactive"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/tvStatus"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Inactive"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintStart_toEndOf="@id/statusDot"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Calibration card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCalibrate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardMain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvCalibrateTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Comment Button Position"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnCalibrate"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalibrate"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Locate"
                android:textSize="13sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/accent"
                app:cornerRadius="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/tvCalibrateTitle"/>

            <TextView
                android:id="@+id/tvCalStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not set — tap Locate to set the comment button position"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvCalibrateTitle"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Open Accessibility Settings -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Open Accessibility Settings"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:backgroundTint="@color/surface"
        app:cornerRadius="16dp"
        app:strokeColor="@color/accent"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/cardCalibrate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
